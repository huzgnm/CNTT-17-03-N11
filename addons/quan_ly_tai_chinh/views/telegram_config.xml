<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Action mo man hinh cau hinh Telegram -->
        <record id="action_telegram_config" model="ir.actions.act_window">
            <field name="name">Cau hinh Telegram</field>
            <field name="res_model">ir.config_parameter</field>
            <field name="view_mode">list</field>
            <field name="domain">[('key', 'like', 'quan_ly_tai_chinh.telegram')]</field>
            <field name="context">{'default_key': 'quan_ly_tai_chinh.telegram_bot_token'}</field>
        </record>

        <!-- Menu Cau hinh Telegram -->
        <menuitem
            id="menu_telegram_config"
            name="Cau hinh Telegram"
            parent="menu_tai_chinh_root"
            action="action_telegram_config"
            sequence="99"/>
    </data>
</odoo>
