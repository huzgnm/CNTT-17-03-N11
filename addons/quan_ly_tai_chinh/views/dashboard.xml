<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_tai_chinh_dashboard_form" model="ir.ui.view">
            <field name="name">tai_chinh.dashboard.form</field>
            <field name="model">tai_chinh.dashboard</field>
            <field name="arch" type="xml">
                <form string="Dashboard Quản lý Tài chính" create="false" edit="false">
                    <field name="currency_id" invisible="1"/>
                    <sheet style="max-width:100%; background:#f4f6f9;">

                        <!-- Header -->
                        <div class="d-flex justify-content-between align-items-center mb-3"
                             style="padding:8px 4px;">
                            <h2 style="margin:0; font-weight:700; color:#2c3e50;">
                                <i class="fa fa-tachometer" style="color:#2980b9;"/>
                                Dashboard Quản lý Tài chính
                            </h2>
                            <button name="action_refresh" type="object"
                                    class="btn btn-primary" icon="fa-refresh">
                                Làm mới
                            </button>
                        </div>

                        <!-- ===== TÀI SẢN ===== -->
                        <h4 style="color:#34495e; font-weight:600; margin:14px 4px 6px;">
                            <i class="fa fa-cubes"/> Tài sản cố định
                        </h4>
                        <div class="row">
                            <div class="col-lg-2 col-md-4 col-6 mb-3">
                                <div style="background:#fff;border-radius:12px;box-shadow:0 2px 6px rgba(0,0,0,.10);border-top:4px solid #3498db;padding:16px 8px;text-align:center;">
                                    <i class="fa fa-cubes fa-2x" title="Tong tai san" style="color:#3498db;"/>
                                    <div style="font-size:28px;font-weight:700;margin-top:6px;color:#2c3e50;"><field name="tong_tai_san"/></div>
                                    <div style="color:#7f8c8d;font-size:12px;">Tổng tài sản</div>
                                </div>
                            </div>
                            <div class="col-lg-2 col-md-4 col-6 mb-3">
                                <div style="background:#fff;border-radius:12px;box-shadow:0 2px 6px rgba(0,0,0,.10);border-top:4px solid #27ae60;padding:16px 8px;text-align:center;">
                                    <i class="fa fa-check-circle fa-2x" title="Dang su dung" style="color:#27ae60;"/>
                                    <div style="font-size:28px;font-weight:700;margin-top:6px;color:#2c3e50;"><field name="tai_san_dang_su_dung"/></div>
                                    <div style="color:#7f8c8d;font-size:12px;">Đang sử dụng</div>
                                </div>
                            </div>
                            <div class="col-lg-2 col-md-4 col-6 mb-3">
                                <div style="background:#fff;border-radius:12px;box-shadow:0 2px 6px rgba(0,0,0,.10);border-top:4px solid #e67e22;padding:16px 8px;text-align:center;">
                                    <i class="fa fa-wrench fa-2x" title="Bao tri" style="color:#e67e22;"/>
                                    <div style="font-size:28px;font-weight:700;margin-top:6px;color:#2c3e50;"><field name="tai_san_bao_tri"/></div>
                                    <div style="color:#7f8c8d;font-size:12px;">Đang bảo trì</div>
                                </div>
                            </div>
                            <div class="col-lg-2 col-md-4 col-6 mb-3">
                                <div style="background:#fff;border-radius:12px;box-shadow:0 2px 6px rgba(0,0,0,.10);border-top:4px solid #e74c3c;padding:16px 8px;text-align:center;">
                                    <i class="fa fa-exclamation-triangle fa-2x" title="Hong" style="color:#e74c3c;"/>
                                    <div style="font-size:28px;font-weight:700;margin-top:6px;color:#2c3e50;"><field name="tai_san_hong"/></div>
                                    <div style="color:#7f8c8d;font-size:12px;">Bị hỏng</div>
                                </div>
                            </div>
                            <div class="col-lg-2 col-md-4 col-6 mb-3">
                                <div style="background:#fff;border-radius:12px;box-shadow:0 2px 6px rgba(0,0,0,.10);border-top:4px solid #95a5a6;padding:16px 8px;text-align:center;">
                                    <i class="fa fa-trash fa-2x" title="Thanh ly" style="color:#95a5a6;"/>
                                    <div style="font-size:28px;font-weight:700;margin-top:6px;color:#2c3e50;"><field name="tai_san_da_thanh_ly"/></div>
                                    <div style="color:#7f8c8d;font-size:12px;">Đã thanh lý</div>
                                </div>
                            </div>
                            <div class="col-lg-2 col-md-4 col-6 mb-3">
                                <div style="background:#fff;border-radius:12px;box-shadow:0 2px 6px rgba(0,0,0,.10);border-top:4px solid #9b59b6;padding:16px 8px;text-align:center;">
                                    <i class="fa fa-hourglass-end fa-2x" title="Het khau hao" style="color:#9b59b6;"/>
                                    <div style="font-size:28px;font-weight:700;margin-top:6px;color:#2c3e50;"><field name="tai_san_het_khau_hao"/></div>
                                    <div style="color:#7f8c8d;font-size:12px;">Hết khấu hao</div>
                                </div>
                            </div>
                        </div>

                        <!-- ===== BẢO TRÌ & THANH LÝ ===== -->
                        <h4 style="color:#34495e; font-weight:600; margin:14px 4px 6px;">
                            <i class="fa fa-cogs"/> Bảo trì &amp; Thanh lý
                        </h4>
                        <div class="row">
                            <div class="col-lg-3 col-md-6 col-6 mb-3">
                                <div style="background:#fff;border-radius:12px;box-shadow:0 2px 6px rgba(0,0,0,.10);border-top:4px solid #f39c12;padding:16px 8px;text-align:center;">
                                    <i class="fa fa-clock-o fa-2x" title="Cho duyet" style="color:#f39c12;"/>
                                    <div style="font-size:28px;font-weight:700;margin-top:6px;color:#2c3e50;"><field name="bao_tri_cho_duyet"/></div>
                                    <div style="color:#7f8c8d;font-size:12px;">Bảo trì chờ duyệt</div>
                                </div>
                            </div>
                            <div class="col-lg-3 col-md-6 col-6 mb-3">
                                <div style="background:#fff;border-radius:12px;box-shadow:0 2px 6px rgba(0,0,0,.10);border-top:4px solid #e67e22;padding:16px 8px;text-align:center;">
                                    <i class="fa fa-wrench fa-2x" title="Bao tri" style="color:#e67e22;"/>
                                    <div style="font-size:28px;font-weight:700;margin-top:6px;color:#2c3e50;"><field name="bao_tri_dang_thuc_hien"/></div>
                                    <div style="color:#7f8c8d;font-size:12px;">Đang thực hiện</div>
                                </div>
                            </div>
                            <div class="col-lg-3 col-md-6 col-6 mb-3">
                                <div style="background:#fff;border-radius:12px;box-shadow:0 2px 6px rgba(0,0,0,.10);border-top:4px solid #27ae60;padding:16px 8px;text-align:center;">
                                    <i class="fa fa-calendar-check-o fa-2x" title="Hoan thanh" style="color:#27ae60;"/>
                                    <div style="font-size:28px;font-weight:700;margin-top:6px;color:#2c3e50;"><field name="bao_tri_hoan_thanh_thang"/></div>
                                    <div style="color:#7f8c8d;font-size:12px;">Hoàn thành tháng này</div>
                                </div>
                            </div>
                            <div class="col-lg-3 col-md-6 col-6 mb-3">
                                <div style="background:#fff;border-radius:12px;box-shadow:0 2px 6px rgba(0,0,0,.10);border-top:4px solid #16a085;padding:16px 8px;text-align:center;">
                                    <i class="fa fa-recycle fa-2x" title="Thu hoi" style="color:#16a085;"/>
                                    <div style="font-size:28px;font-weight:700;margin-top:6px;color:#2c3e50;"><field name="thanh_ly_cho_duyet"/></div>
                                    <div style="color:#7f8c8d;font-size:12px;">Thanh lý chờ duyệt</div>
                                </div>
                            </div>
                        </div>

                        <!-- ===== THU / CHI ===== -->
                        <h4 style="color:#34495e; font-weight:600; margin:14px 4px 6px;">
                            <i class="fa fa-money"/> Thu / Chi tháng này
                        </h4>
                        <div class="row">
                            <div class="col-lg-3 col-md-6 col-6 mb-3">
                                <div style="background:#fff;border-radius:12px;box-shadow:0 2px 6px rgba(0,0,0,.10);border-top:4px solid #27ae60;padding:16px 8px;text-align:center;">
                                    <i class="fa fa-arrow-down fa-2x" title="Thu" style="color:#27ae60;"/>
                                    <div style="font-size:22px;font-weight:700;margin-top:6px;color:#27ae60;"><field name="tong_thu_thang" widget="monetary"/></div>
                                    <div style="color:#7f8c8d;font-size:12px;">Tổng thu đã duyệt</div>
                                </div>
                            </div>
                            <div class="col-lg-3 col-md-6 col-6 mb-3">
                                <div style="background:#fff;border-radius:12px;box-shadow:0 2px 6px rgba(0,0,0,.10);border-top:4px solid #2ecc71;padding:16px 8px;text-align:center;">
                                    <i class="fa fa-inbox fa-2x" title="Phieu thu" style="color:#2ecc71;"/>
                                    <div style="font-size:28px;font-weight:700;margin-top:6px;color:#2c3e50;"><field name="phieu_thu_cho_duyet"/></div>
                                    <div style="color:#7f8c8d;font-size:12px;">Phiếu thu chờ duyệt</div>
                                </div>
                            </div>
                            <div class="col-lg-3 col-md-6 col-6 mb-3">
                                <div style="background:#fff;border-radius:12px;box-shadow:0 2px 6px rgba(0,0,0,.10);border-top:4px solid #e74c3c;padding:16px 8px;text-align:center;">
                                    <i class="fa fa-arrow-up fa-2x" title="Chi" style="color:#e74c3c;"/>
                                    <div style="font-size:22px;font-weight:700;margin-top:6px;color:#e74c3c;"><field name="tong_chi_thang" widget="monetary"/></div>
                                    <div style="color:#7f8c8d;font-size:12px;">Tổng chi đã duyệt</div>
                                </div>
                            </div>
                            <div class="col-lg-3 col-md-6 col-6 mb-3">
                                <div style="background:#fff;border-radius:12px;box-shadow:0 2px 6px rgba(0,0,0,.10);border-top:4px solid #c0392b;padding:16px 8px;text-align:center;">
                                    <i class="fa fa-outbox fa-2x" title="Phieu chi" style="color:#c0392b;"/>
                                    <div style="font-size:28px;font-weight:700;margin-top:6px;color:#2c3e50;"><field name="phieu_chi_cho_duyet"/></div>
                                    <div style="color:#7f8c8d;font-size:12px;">Phiếu chi chờ duyệt</div>
                                </div>
                            </div>
                        </div>

                        <!-- ===== KHẤU HAO ===== -->
                        <h4 style="color:#34495e; font-weight:600; margin:14px 4px 6px;">
                            <i class="fa fa-line-chart"/> Khấu hao
                        </h4>
                        <div class="row">
                            <div class="col-lg-4 col-md-6 col-12 mb-3">
                                <div style="background:linear-gradient(135deg,#8e44ad,#9b59b6);border-radius:12px;box-shadow:0 2px 8px rgba(0,0,0,.15);padding:20px;text-align:center;color:#fff;">
                                    <i class="fa fa-line-chart fa-2x" title="Khau hao"/>
                                    <div style="font-size:24px;font-weight:700;margin-top:6px;"><field name="khau_hao_thang" widget="monetary"/></div>
                                    <div style="font-size:13px;opacity:.9;">Khấu hao đã ghi sổ tháng này</div>
                                </div>
                            </div>
                        </div>

                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_tai_chinh_dashboard" model="ir.actions.act_window">
            <field name="name">Dashboard</field>
            <field name="res_model">tai_chinh.dashboard</field>
            <field name="view_mode">form</field>
            <field name="target">inline</field>
        </record>
    </data>
</odoo>
