<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bao_cao_tai_chinh_tree" model="ir.ui.view">
        <field name="name">tai_chinh.bao_cao.tree</field>
        <field name="model">tai_chinh.bao_cao</field>
        <field name="arch" type="xml">
            <tree string="Báo cáo tài chính">
                <field name="ma_bao_cao"/>
                <field name="ten_bao_cao"/>
                <field name="ky_bao_cao"/>
                <field name="thang" attrs="{'invisible': [('ky_bao_cao', '!=', 'thang')]}"/>
                <field name="quy" attrs="{'invisible': [('ky_bao_cao', '!=', 'quy')]}"/>
                <field name="nam"/>
                <field name="tong_thu" widget="monetary"/>
                <field name="tong_chi" widget="monetary"/>
                <field name="can_doi" widget="monetary"
                       decoration-success="can_doi &gt;= 0"
                       decoration-danger="can_doi &lt; 0"/>
                <field name="nguoi_lap_id"/>
                <field name="trang_thai" widget="badge"/>
            </tree>
        </field>
    </record>

    <record id="view_bao_cao_tai_chinh_form" model="ir.ui.view">
        <field name="name">tai_chinh.bao_cao.form</field>
        <field name="model">tai_chinh.bao_cao</field>
        <field name="arch" type="xml">
            <form string="Báo cáo tài chính">
                <header>
                    <button name="action_tinh_toan" string="Tính toán lại" type="object"
                            class="btn-primary"
                            attrs="{'invisible': [('trang_thai', '=', 'da_duyet')]}"/>
                    <button name="action_duyet" string="Duyệt báo cáo" type="object"
                            class="btn-success"
                            attrs="{'invisible': [('trang_thai', '!=', 'nhap')]}"/>
                    <field name="trang_thai" widget="statusbar"
                           statusbar_visible="nhap,da_duyet"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="ten_bao_cao"/></h1>
                        <h3><field name="ma_bao_cao" readonly="1"/></h3>
                    </div>
                    <group>
                        <group string="Kỳ báo cáo">
                            <field name="ky_bao_cao"/>
                            <field name="thang"
                                   attrs="{'invisible': [('ky_bao_cao', '!=', 'thang')],
                                           'required': [('ky_bao_cao', '=', 'thang')]}"/>
                            <field name="quy"
                                   attrs="{'invisible': [('ky_bao_cao', '!=', 'quy')],
                                           'required': [('ky_bao_cao', '=', 'quy')]}"/>
                            <field name="nam"/>
                        </group>
                        <group string="Người lập">
                            <field name="nguoi_lap_id"/>
                            <field name="nguoi_duyet_id" readonly="1"/>
                            <field name="ngay_lap"/>
                        </group>
                    </group>
                    <group string="Tổng hợp thu chi">
                        <group>
                            <field name="tong_thu" widget="monetary" readonly="1"/>
                            <field name="tong_chi" widget="monetary" readonly="1"/>
                            <field name="can_doi" widget="monetary" readonly="1"/>
                        </group>
                        <group>
                            <field name="chi_bao_tri" widget="monetary" readonly="1"/>
                            <field name="chi_mua_sam" widget="monetary" readonly="1"/>
                            <field name="thu_thanh_ly" widget="monetary" readonly="1"/>
                        </group>
                    </group>
                    <group string="Ghi chú">
                        <field name="ghi_chu" nolabel="1"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_bao_cao_tai_chinh" model="ir.actions.act_window">
        <field name="name">Báo cáo tài chính</field>
        <field name="res_model">tai_chinh.bao_cao</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
