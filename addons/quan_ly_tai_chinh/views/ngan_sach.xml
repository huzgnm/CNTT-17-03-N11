<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ngan_sach_tree" model="ir.ui.view">
        <field name="name">tai_chinh.ngan_sach.tree</field>
        <field name="model">tai_chinh.ngan_sach</field>
        <field name="arch" type="xml">
            <tree string="Ngân sách"
                  decoration-danger="phan_tram_su_dung &gt; 100"
                  decoration-warning="phan_tram_su_dung &gt; 80"
                  decoration-success="trang_thai == 'da_duyet'">
                <field name="ma_ngan_sach"/>
                <field name="ten_ngan_sach"/>
                <field name="nam"/>
                <field name="loai_ngan_sach"/>
                <field name="tong_ngan_sach" widget="monetary" sum="Tổng NS"/>
                <field name="da_su_dung" widget="monetary" sum="Đã dùng"/>
                <field name="con_lai" widget="monetary"/>
                <field name="phan_tram_su_dung" widget="progressbar"/>
                <field name="trang_thai" widget="badge"
                       decoration-success="trang_thai == 'da_duyet'"
                       decoration-warning="trang_thai == 'cho_duyet'"
                       decoration-danger="trang_thai == 'huy'"/>
            </tree>
        </field>
    </record>

    <record id="view_ngan_sach_form" model="ir.ui.view">
        <field name="name">tai_chinh.ngan_sach.form</field>
        <field name="model">tai_chinh.ngan_sach</field>
        <field name="arch" type="xml">
            <form string="Ngân sách">
                <header>
                    <button name="action_gui_duyet" string="Gửi duyệt" type="object"
                            class="btn-primary"
                            attrs="{'invisible': [('trang_thai', '!=', 'nhap')]}"/>
                    <button name="action_duyet" string="Duyệt" type="object"
                            class="btn-success"
                            attrs="{'invisible': [('trang_thai', '!=', 'cho_duyet')]}"/>
                    <button name="action_huy" string="Hủy" type="object"
                            attrs="{'invisible': [('trang_thai', 'in', ['da_duyet', 'huy'])]}"/>
                    <field name="trang_thai" widget="statusbar"
                           statusbar_visible="nhap,cho_duyet,da_duyet"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="ten_ngan_sach"/></h1>
                        <h3><field name="ma_ngan_sach" readonly="1"/></h3>
                    </div>
                    <group>
                        <group string="Thông tin ngân sách">
                            <field name="nam"/>
                            <field name="loai_ngan_sach"/>
                            <field name="tong_ngan_sach" widget="monetary"/>
                            <field name="canh_bao_vuot"/>
                        </group>
                        <group string="Phụ trách">
                            <field name="nguoi_lap_id"/>
                            <field name="nguoi_duyet_id" readonly="1"/>
                        </group>
                    </group>
                    <group string="Tình hình sử dụng">
                        <group>
                            <field name="da_su_dung" widget="monetary" readonly="1"/>
                            <field name="con_lai" widget="monetary" readonly="1"/>
                        </group>
                        <group>
                            <field name="phan_tram_su_dung" widget="progressbar" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Danh sách phiếu chi">
                            <field name="phieu_chi_ids" readonly="1">
                                <tree>
                                    <field name="ma_phieu"/>
                                    <field name="ten_noi_dung"/>
                                    <field name="nguon_goc"/>
                                    <field name="so_tien" widget="monetary" sum="Tổng"/>
                                    <field name="ngay_lap"/>
                                    <field name="trang_thai"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_ngan_sach_search" model="ir.ui.view">
        <field name="name">tai_chinh.ngan_sach.search</field>
        <field name="model">tai_chinh.ngan_sach</field>
        <field name="arch" type="xml">
            <search>
                <field name="ten_ngan_sach"/>
                <field name="ma_ngan_sach"/>
                <filter string="Năm nay" name="nam_nay"
                        domain="[('nam', '=', context_today().year)]"/>
                <filter string="Chờ duyệt" name="cho_duyet"
                        domain="[('trang_thai', '=', 'cho_duyet')]"/>
                <filter string="Đã duyệt" name="da_duyet"
                        domain="[('trang_thai', '=', 'da_duyet')]"/>
                <filter string="Vượt ngân sách" name="vuot_ns"
                        domain="[('phan_tram_su_dung', '&gt;', 100)]"/>
                <group expand="0" string="Nhóm theo">
                    <filter name="group_nam" string="Năm" context="{'group_by': 'nam'}"/>
                    <filter name="group_loai" string="Loại" context="{'group_by': 'loai_ngan_sach'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_ngan_sach" model="ir.actions.act_window">
        <field name="name">Ngân sách</field>
        <field name="res_model">tai_chinh.ngan_sach</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_ngan_sach_search"/>
    </record>
</odoo>
