<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_thanh_ly_form" model="ir.ui.view">
            <field name="name">thanh_ly.form</field>
            <field name="model">thanh_ly</field>
            <field name="arch" type="xml">
                <form string="Thanh lý tài sản">
                    <header>
                        <button name="action_duyet" string="Duyệt thanh lý"
                            type="object" class="btn-success"
                            attrs="{'invisible': [('trang_thai', '!=', 'cho_duyet')]}"
                            confirm="Xác nhận duyệt phiếu thanh lý này?"/>
                        <button name="action_huy" string="Hủy"
                            type="object" class="btn-danger"
                            confirm="Bạn có chắc muốn hủy phiếu thanh lý này?"
                            attrs="{'invisible': [('trang_thai', '=', 'huy')]}"/>
                        <field name="trang_thai" widget="statusbar"
                            statusbar_visible="cho_duyet,da_duyet"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="ma_thanh_ly" readonly="1"/></h1>
                        </div>
                        <group>
                            <group string="Thông tin cơ bản">
                                <field name="tai_san_id"/>
                                <field name="nguoi_lap_id"/>
                                <field name="ngay_thanh_ly"/>
                            </group>
                            <group string="Giá trị tài chính">
                                <field name="gia_tri_con_lai" readonly="1" widget="monetary"/>
                                <field name="gia_tri_thanh_ly" widget="monetary"/>
                                <field name="lai_lo_thanh_ly" readonly="1" widget="monetary"/>
                            </group>
                        </group>
                        <group>
                            <field name="ly_do"/>
                            <field name="ghi_chu"/>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="view_thanh_ly_tree" model="ir.ui.view">
            <field name="name">thanh_ly.tree</field>
            <field name="model">thanh_ly</field>
            <field name="arch" type="xml">
                <tree string="Danh sách thanh lý">
                    <field name="ma_thanh_ly"/>
                    <field name="tai_san_id"/>
                    <field name="nguoi_lap_id"/>
                    <field name="ngay_thanh_ly"/>
                    <field name="gia_tri_con_lai" widget="monetary" sum="Tổng còn lại"/>
                    <field name="gia_tri_thanh_ly" widget="monetary" sum="Tổng thu hồi"/>
                    <field name="lai_lo_thanh_ly" widget="monetary" sum="Lãi/(Lỗ)"/>
                    <field name="trang_thai" widget="badge"
                        decoration-warning="trang_thai == 'cho_duyet'"
                        decoration-success="trang_thai == 'da_duyet'"
                        decoration-danger="trang_thai == 'huy'"/>
                </tree>
            </field>
        </record>

        <record id="thanh_ly_search" model="ir.ui.view">
            <field name="name">thanh_ly.search</field>
            <field name="model">thanh_ly</field>
            <field name="arch" type="xml">
                <search string="Tìm kiếm thanh lý">
                    <field name="ma_thanh_ly"/>
                    <field name="tai_san_id"/>
                    <field name="nguoi_lap_id"/>
                    <filter string="Chờ duyệt" name="cho_duyet"
                        domain="[('trang_thai','=','cho_duyet')]"/>
                    <filter string="Đã duyệt" name="da_duyet"
                        domain="[('trang_thai','=','da_duyet')]"/>
                    <filter string="Đã hủy" name="huy"
                        domain="[('trang_thai','=','huy')]"/>
                    <separator/>
                    <group expand="0" string="Nhóm theo">
                        <filter string="Trạng thái" name="group_trang_thai"
                            context="{'group_by': 'trang_thai'}"/>
                        <filter string="Tháng" name="group_thang"
                            context="{'group_by': 'ngay_thanh_ly:month'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_thanh_ly" model="ir.actions.act_window">
            <field name="name">Thanh lý tài sản</field>
            <field name="res_model">thanh_ly</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="thanh_ly_search"/>
        </record>
    </data>
</odoo>
