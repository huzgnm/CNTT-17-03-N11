<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_tai_san_form" model="ir.ui.view">
            <field name="name">tai_san.form</field>
            <field name="model">tai_san</field>
            <field name="arch" type="xml">
                <form string="Tài sản">
                    <header>
                        <button name="action_ghi_so_mua_tai_san" string="Ghi sổ mua tài sản"
                            type="object" class="btn-primary"
                            attrs="{'invisible': [('da_ghi_so_mua', '=', True)]}"/>
                        <button name="action_xem_but_toan_mua" string="Xem bút toán mua"
                            type="object"
                            attrs="{'invisible': [('da_ghi_so_mua', '=', False)]}"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="%(action_muon_tra)d" type="action"
                                class="oe_stat_button" icon="fa-exchange">
                                <field name="so_lan_muon" string="Lần mượn" widget="statinfo"/>
                            </button>
                            <button name="%(action_bao_tri)d" type="action"
                                class="oe_stat_button" icon="fa-wrench">
                                <field name="so_lan_bao_tri" string="Bảo trì" widget="statinfo"/>
                            </button>
                            <button name="%(action_thanh_ly)d" type="action"
                                class="oe_stat_button" icon="fa-trash">
                                <field name="so_lan_thanh_ly" string="Thanh lý" widget="statinfo"/>
                            </button>
                            <button name="%(action_dieu_chuyen_tai_san)d" type="action"
                                class="oe_stat_button" icon="fa-arrows">
                                <field name="so_lan_dieu_chuyen" string="Điều chuyển" widget="statinfo"/>
                            </button>
                        </div>
                        <div class="oe_title">
                            <h1><field name="ma_tai_san" readonly="1"/></h1>
                        </div>
                        <group>
                            <group string="Thông tin cơ bản">
                                <field name="ten_tai_san"/>
                                <field name="danh_muc_loai_tai_san_id"/>
                                <field name="nha_cung_cap_id"/>
                                <field name="ngay_mua"/>
                                <field name="ngay_su_dung"/>
                                <field name="vi_tri"/>
                                <field name="trang_thai"/>
                            </group>
                            <group string="Thông tin tài chính">
                                <field name="nguyen_gia" widget="monetary"/>
                                <field name="gia_tri_con_lai" readonly="1" widget="monetary"/>
                                <field name="tong_da_khau_hao" readonly="1" widget="monetary"/>
                                <field name="thoi_gian_su_dung"/>
                                <field name="ty_le_khau_hao" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Kế toán mua">
                                <group>
                                    <group string="Thiết lập kế toán mua">
                                        <field name="journal_mua_id"
                                            domain="[('type', 'in', ['general', 'purchase'])]"/>
                                        <field name="tai_khoan_tai_san_id"/>
                                        <field name="tai_khoan_phai_tra_mua_id"/>
                                        <field name="da_ghi_so_mua" readonly="1"/>
                                        <field name="account_move_mua_id" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Kế toán khấu hao">
                                <group>
                                    <group string="Thiết lập kế toán khấu hao">
                                        <field name="journal_khau_hao_id"/>
                                        <field name="tai_khoan_chi_phi_khau_hao_id"/>
                                        <field name="tai_khoan_hao_mon_luy_ke_id"/>
                                    </group>
                                </group>
                                <field name="khau_hao_hang_thang_ids" readonly="1">
                                    <tree string="Lịch khấu hao hàng tháng">
                                        <field name="thang"/>
                                        <field name="nam"/>
                                        <field name="gia_tri_khau_hao" widget="monetary" sum="Tổng KH"/>
                                        <field name="gia_tri_con_lai" widget="monetary"/>
                                        <field name="da_ghi_so"/>
                                        <field name="account_move_id"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Lịch sử mượn trả">
                                <field name="muon_tra_ids" readonly="1">
                                    <tree string="Lịch sử mượn trả">
                                        <field name="ma_muon_tra"/>
                                        <field name="nguoi_muon_id"/>
                                        <field name="ngay_muon"/>
                                        <field name="ngay_tra"/>
                                        <field name="trang_thai"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Lịch sử bảo trì">
                                <field name="lich_su_bao_tri_tai_san_ids" readonly="1">
                                    <tree string="Lịch sử bảo trì">
                                        <field name="ma_bao_tri"/>
                                        <field name="ngay_bao_tri"/>
                                        <field name="nha_cung_cap_id"/>
                                        <field name="chi_phi_bao_tri" widget="monetary" sum="Tổng"/>
                                        <field name="tinh_trang"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Lịch sử thanh lý">
                                <field name="lich_su_thanh_ly_tai_san_ids" readonly="1">
                                    <tree string="Lịch sử thanh lý">
                                        <field name="ma_thanh_ly"/>
                                        <field name="ngay_thanh_ly"/>
                                        <field name="gia_tri_thanh_ly" widget="monetary" sum="Tổng"/>
                                        <field name="lai_lo_thanh_ly" widget="monetary" sum="Lãi/(Lỗ)"/>
                                        <field name="trang_thai"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Lịch sử điều chuyển">
                                <field name="lich_su_dieu_chuyen_tai_san_ids" readonly="1">
                                    <tree string="Lịch sử điều chuyển">
                                        <field name="ma_dieu_chuyen"/>
                                        <field name="ngay_dieu_chuyen"/>
                                        <field name="dia_diem_cu"/>
                                        <field name="dia_diem_moi"/>
                                        <field name="ly_do"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Lịch sử sử dụng">
                                <field name="lich_su_su_dung_tai_san_ids" readonly="1">
                                    <tree string="Lịch sử sử dụng">
                                        <field name="ngay_bat_dau"/>
                                        <field name="ngay_ket_thuc"/>
                                        <field name="nguoi_su_dung_id"/>
                                        <field name="ghi_chu"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Lịch sử quản lý">
                                <field name="lich_su_quan_ly_tai_san_ids" readonly="1">
                                    <tree string="Lịch sử quản lý">
                                        <field name="ngay_thay_doi"/>
                                        <field name="nguoi_quan_ly_id"/>
                                        <field name="trang_thai_cu"/>
                                        <field name="trang_thai_moi"/>
                                        <field name="ghi_chu"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="view_tai_san_tree" model="ir.ui.view">
            <field name="name">tai_san.tree</field>
            <field name="model">tai_san</field>
            <field name="arch" type="xml">
                <tree string="Danh sách tài sản">
                    <field name="ma_tai_san"/>
                    <field name="ten_tai_san"/>
                    <field name="danh_muc_loai_tai_san_id"/>
                    <field name="nha_cung_cap_id"/>
                    <field name="ngay_mua"/>
                    <field name="nguyen_gia" widget="monetary" sum="Tổng nguyên giá"/>
                    <field name="gia_tri_con_lai" widget="monetary" sum="Tổng còn lại"/>
                    <field name="vi_tri"/>
                    <field name="da_ghi_so_mua" string="Đã ghi sổ mua"/>
                    <field name="trang_thai" widget="badge"
                        decoration-success="trang_thai == 'dang_su_dung'"
                        decoration-warning="trang_thai == 'bao_tri'"
                        decoration-danger="trang_thai in ('hong', 'da_thanh_ly')"
                        decoration-info="trang_thai == 'cho_su_dung'"/>
                </tree>
            </field>
        </record>

        <record id="view_tai_san_search" model="ir.ui.view">
            <field name="name">tai_san.search</field>
            <field name="model">tai_san</field>
            <field name="arch" type="xml">
                <search string="Tìm kiếm tài sản">
                    <field name="ma_tai_san"/>
                    <field name="ten_tai_san"/>
                    <field name="danh_muc_loai_tai_san_id"/>
                    <field name="nha_cung_cap_id"/>
                    <field name="vi_tri"/>
                    <filter string="Đang sử dụng" name="dang_su_dung"
                        domain="[('trang_thai','=','dang_su_dung')]"/>
                    <filter string="Bảo trì" name="bao_tri"
                        domain="[('trang_thai','=','bao_tri')]"/>
                    <filter string="Hỏng" name="hong"
                        domain="[('trang_thai','=','hong')]"/>
                    <filter string="Chưa ghi sổ mua" name="chua_ghi_so_mua"
                        domain="[('da_ghi_so_mua','=',False)]"/>
                    <separator/>
                    <group expand="0" string="Nhóm theo">
                        <filter string="Loại tài sản" name="group_loai"
                            context="{'group_by': 'danh_muc_loai_tai_san_id'}"/>
                        <filter string="Trạng thái" name="group_trang_thai"
                            context="{'group_by': 'trang_thai'}"/>
                        <filter string="Nhà cung cấp" name="group_ncc"
                            context="{'group_by': 'nha_cung_cap_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_tai_san" model="ir.actions.act_window">
            <field name="name">Tài sản</field>
            <field name="res_model">tai_san</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_tai_san_search"/>
            <field name="context">{'search_default_dang_su_dung': 1}</field>
        </record>
    </data>
</odoo>
