<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ================================================================ -->
        <!-- FORM VIEW                                                         -->
        <!-- ================================================================ -->
        <record id="view_ngan_sach_mua_sam_form" model="ir.ui.view">
            <field name="name">ngan_sach_mua_sam.form</field>
            <field name="model">ngan_sach_mua_sam</field>
            <field name="arch" type="xml">
                <form string="Ngân sách mua sắm">
                    <header>
                        <button name="action_gui_duyet" string="Gửi duyệt"
                            type="object" class="btn-primary"
                            attrs="{'invisible': [('trang_thai', '!=', 'lap_ke_hoach')]}"/>
                        <button name="action_duyet" string="Duyệt"
                            type="object" class="btn-success"
                            attrs="{'invisible': [('trang_thai', '!=', 'cho_duyet')]}"/>
                        <button name="action_bat_dau_thuc_hien" string="Bắt đầu thực hiện"
                            type="object"
                            attrs="{'invisible': [('trang_thai', '!=', 'da_duyet')]}"/>
                        <button name="action_cap_nhat_trang_thai" string="Cập nhật trạng thái"
                            type="object"
                            attrs="{'invisible': [('trang_thai', '!=', 'dang_thuc_hien')]}"/>
                        <button name="action_hoan_thanh" string="Hoàn thành"
                            type="object" class="btn-success"
                            attrs="{'invisible': [('trang_thai', 'not in', ['dang_thuc_hien', 'vuot_ngan_sach'])]}"/>
                        <button name="action_huy" string="Hủy"
                            type="object" class="btn-danger"
                            confirm="Bạn có chắc muốn hủy ngân sách này?"
                            attrs="{'invisible': [('trang_thai', 'in', ['hoan_thanh', 'huy'])]}"/>
                        <button name="action_xem_tai_san" string="Xem tài sản đã mua"
                            type="object"
                            attrs="{'invisible': [('so_tai_san_da_mua', '=', 0)]}"/>
                        <field name="trang_thai" widget="statusbar"
                            statusbar_visible="lap_ke_hoach,cho_duyet,da_duyet,dang_thuc_hien,hoan_thanh"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_xem_tai_san" type="object"
                                class="oe_stat_button" icon="fa-list"
                                attrs="{'invisible': [('so_tai_san_da_mua', '=', 0)]}">
                                <field name="so_tai_san_da_mua" widget="statinfo" string="Tài sản đã mua"/>
                            </button>
                        </div>

                        <div class="alert alert-warning" role="alert"
                            attrs="{'invisible': [('canh_bao_vuot', '=', False)]}">
                            <strong>Cảnh báo:</strong> Chi tiêu thực tế đã <strong>vượt ngân sách</strong> kế hoạch!
                        </div>

                        <div class="oe_title">
                            <label for="ma_ngan_sach"/>
                            <h1><field name="ma_ngan_sach" readonly="1"/></h1>
                            <h2><field name="ten_ngan_sach" placeholder="Tên ngân sách..."/></h2>
                        </div>

                        <group>
                            <group string="Thông tin chung">
                                <field name="nam"/>
                                <field name="danh_muc_loai_tai_san_id"/>
                                <field name="nguoi_lap_id"/>
                                <field name="nguoi_duyet_id"/>
                                <field name="ngay_duyet" readonly="1"/>
                            </group>
                            <group string="Tài chính">
                                <field name="so_tien_ke_hoach" widget="monetary"/>
                                <field name="so_tien_thuc_te" readonly="1" widget="monetary"/>
                                <field name="chenh_lech" readonly="1" widget="monetary"/>
                                <field name="ty_le_thuc_hien" readonly="1" widget="percentage"/>
                                <field name="canh_bao_vuot" invisible="1"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="Chi tiết theo tháng" name="chi_tiet">
                                <field name="chi_tiet_ids">
                                    <tree editable="bottom">
                                        <field name="thang"/>
                                        <field name="ten_thang" readonly="1"/>
                                        <field name="so_tien_ke_hoach" widget="monetary"/>
                                        <field name="so_tien_thuc_te" readonly="1" widget="monetary"/>
                                        <field name="chenh_lech" readonly="1" widget="monetary"
                                            decoration-danger="chenh_lech &lt; 0"
                                            decoration-success="chenh_lech &gt;= 0"/>
                                        <field name="ghi_chu"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Mô tả" name="mo_ta">
                                <field name="mo_ta"/>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- ================================================================ -->
        <!-- TREE VIEW                                                         -->
        <!-- ================================================================ -->
        <record id="view_ngan_sach_mua_sam_tree" model="ir.ui.view">
            <field name="name">ngan_sach_mua_sam.tree</field>
            <field name="model">ngan_sach_mua_sam</field>
            <field name="arch" type="xml">
                <tree string="Ngân sách mua sắm"
                    decoration-danger="canh_bao_vuot == True">
                    <field name="ma_ngan_sach"/>
                    <field name="ten_ngan_sach"/>
                    <field name="nam"/>
                    <field name="danh_muc_loai_tai_san_id"/>
                    <field name="so_tien_ke_hoach" widget="monetary" sum="Tổng kế hoạch"/>
                    <field name="so_tien_thuc_te" widget="monetary" sum="Tổng thực tế"/>
                    <field name="chenh_lech" widget="monetary" sum="Chênh lệch"/>
                    <field name="ty_le_thuc_hien" widget="percentage"/>
                    <field name="so_tai_san_da_mua"/>
                    <field name="canh_bao_vuot" invisible="1"/>
                    <field name="trang_thai" widget="badge"
                        decoration-info="trang_thai == 'lap_ke_hoach'"
                        decoration-warning="trang_thai in ('cho_duyet', 'dang_thuc_hien')"
                        decoration-success="trang_thai == 'hoan_thanh'"
                        decoration-danger="trang_thai in ('vuot_ngan_sach', 'huy')"
                        decoration-primary="trang_thai == 'da_duyet'"/>
                </tree>
            </field>
        </record>

        <!-- ================================================================ -->
        <!-- GRAPH VIEW                                                        -->
        <!-- ================================================================ -->
        <record id="view_ngan_sach_mua_sam_graph" model="ir.ui.view">
            <field name="name">ngan_sach_mua_sam.graph</field>
            <field name="model">ngan_sach_mua_sam</field>
            <field name="arch" type="xml">
                <graph string="Ngân sách mua sắm" type="bar">
                    <field name="ten_ngan_sach" type="row"/>
                    <field name="so_tien_ke_hoach" type="measure"/>
                    <field name="so_tien_thuc_te" type="measure"/>
                </graph>
            </field>
        </record>

        <!-- ================================================================ -->
        <!-- SEARCH VIEW                                                       -->
        <!-- ================================================================ -->
        <record id="view_ngan_sach_mua_sam_search" model="ir.ui.view">
            <field name="name">ngan_sach_mua_sam.search</field>
            <field name="model">ngan_sach_mua_sam</field>
            <field name="arch" type="xml">
                <search string="Tìm kiếm ngân sách">
                    <field name="ten_ngan_sach"/>
                    <field name="ma_ngan_sach"/>
                    <field name="danh_muc_loai_tai_san_id"/>
                    <filter string="Đang thực hiện" name="dang_thuc_hien" domain="[('trang_thai','=','dang_thuc_hien')]"/>
                    <filter string="Vượt ngân sách" name="vuot" domain="[('canh_bao_vuot','=',True)]"/>
                    <filter string="Hoàn thành" name="hoan_thanh" domain="[('trang_thai','=','hoan_thanh')]"/>
                    <separator/>
                    <group expand="0" string="Nhóm theo">
                        <filter string="Năm" name="group_nam" context="{'group_by': 'nam'}"/>
                        <filter string="Trạng thái" name="group_trang_thai" context="{'group_by': 'trang_thai'}"/>
                        <filter string="Loại tài sản" name="group_loai" context="{'group_by': 'danh_muc_loai_tai_san_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ================================================================ -->
        <!-- ACTION                                                            -->
        <!-- ================================================================ -->
        <record id="action_ngan_sach_mua_sam" model="ir.actions.act_window">
            <field name="name">Ngân sách mua sắm</field>
            <field name="res_model">ngan_sach_mua_sam</field>
            <field name="view_mode">tree,form,graph</field>
            <field name="search_view_id" ref="view_ngan_sach_mua_sam_search"/>
            <field name="context">{'search_default_dang_thuc_hien': 1}</field>
        </record>

    </data>
</odoo>
