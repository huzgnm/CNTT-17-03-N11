<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ================================================================ -->
        <!-- FORM VIEW                                                         -->
        <!-- ================================================================ -->
        <record id="view_bao_cao_tai_san_form" model="ir.ui.view">
            <field name="name">bao_cao_tai_san.form</field>
            <field name="model">bao_cao_tai_san</field>
            <field name="arch" type="xml">
                <form string="Báo cáo tài chính tài sản">
                    <header>
                        <button name="action_lam_moi" string="Làm mới số liệu"
                            type="object" class="btn-primary" icon="fa-refresh"/>
                        <button name="action_tao_bao_cao_day_du" string="Tạo báo cáo đầy đủ"
                            type="object" class="btn-success"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="ten_bao_cao"/>
                            <h1><field name="ten_bao_cao" placeholder="Tên báo cáo..."/></h1>
                        </div>

                        <group>
                            <group>
                                <field name="nam_bao_cao"/>
                                <field name="ngay_tao" readonly="1"/>
                                <field name="nguoi_tao_id"/>
                            </group>
                            <group>
                                <field name="ghi_chu"/>
                            </group>
                        </group>

                        <!-- Tổng quan tài sản -->
                        <group string="Tổng quan tài sản (tất cả thời điểm)">
                            <group>
                                <field name="tong_so_tai_san" readonly="1"/>
                                <field name="tong_nguyen_gia" readonly="1" widget="monetary"/>
                                <field name="tong_da_khau_hao" readonly="1" widget="monetary"/>
                                <field name="tong_gia_tri_con_lai" readonly="1" widget="monetary"/>
                            </group>
                            <group string="Theo trạng thái">
                                <field name="so_dang_su_dung" readonly="1" string="Đang sử dụng"/>
                                <field name="so_bao_tri" readonly="1" string="Đang bảo trì"/>
                                <field name="so_hong" readonly="1" string="Hỏng / Mất"/>
                            </group>
                        </group>

                        <!-- Hoạt động trong năm -->
                        <group string="Hoạt động trong năm">
                            <group string="Mua sắm">
                                <field name="so_mua_trong_nam" readonly="1"/>
                                <field name="tong_gia_tri_mua" readonly="1" widget="monetary"/>
                            </group>
                            <group string="Khấu hao">
                                <field name="so_ky_khau_hao" readonly="1"/>
                                <field name="khau_hao_trong_nam" readonly="1" widget="monetary"/>
                            </group>
                            <group string="Bảo trì">
                                <field name="so_lan_bao_tri" readonly="1"/>
                                <field name="tong_chi_phi_bao_tri" readonly="1" widget="monetary"/>
                            </group>
                            <group string="Thanh lý">
                                <field name="so_lan_thanh_ly" readonly="1"/>
                                <field name="tong_thu_hoi_thanh_ly" readonly="1" widget="monetary"/>
                                <field name="lai_lo_thanh_ly" readonly="1" widget="monetary"/>
                            </group>
                        </group>

                        <!-- Mượn trả -->
                        <group>
                            <field name="so_lan_muon" readonly="1" string="Số lần mượn tài sản trong năm"/>
                        </group>

                        <!-- Chi tiết theo loại tài sản -->
                        <notebook>
                            <page string="Chi tiết theo loại tài sản" name="chi_tiet">
                                <field name="chi_tiet_ids" readonly="1">
                                    <tree>
                                        <field name="danh_muc_loai_tai_san_id"/>
                                        <field name="so_tai_san"/>
                                        <field name="tong_nguyen_gia" widget="monetary" sum="Tổng nguyên giá"/>
                                        <field name="tong_da_khau_hao" widget="monetary" sum="Tổng đã KH"/>
                                        <field name="tong_gia_tri_con_lai" widget="monetary" sum="Còn lại"/>
                                        <field name="ty_le_khau_hao" widget="percentage"/>
                                        <field name="khau_hao_trong_nam" widget="monetary" sum="KH trong năm"/>
                                        <field name="chi_phi_bao_tri" widget="monetary" sum="Chi phí BT"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ================================================================ -->
        <!-- TREE VIEW                                                         -->
        <!-- ================================================================ -->
        <record id="view_bao_cao_tai_san_tree" model="ir.ui.view">
            <field name="name">bao_cao_tai_san.tree</field>
            <field name="model">bao_cao_tai_san</field>
            <field name="arch" type="xml">
                <tree string="Báo cáo tài sản">
                    <field name="ten_bao_cao"/>
                    <field name="nam_bao_cao"/>
                    <field name="ngay_tao"/>
                    <field name="tong_so_tai_san"/>
                    <field name="tong_nguyen_gia" widget="monetary" sum="Tổng nguyên giá"/>
                    <field name="tong_da_khau_hao" widget="monetary" sum="Tổng đã KH"/>
                    <field name="tong_gia_tri_con_lai" widget="monetary" sum="Tổng còn lại"/>
                    <field name="khau_hao_trong_nam" widget="monetary" sum="KH trong năm"/>
                    <field name="tong_chi_phi_bao_tri" widget="monetary" sum="Chi phí BT"/>
                    <field name="nguoi_tao_id"/>
                </tree>
            </field>
        </record>

        <!-- ================================================================ -->
        <!-- ACTION                                                            -->
        <!-- ================================================================ -->
        <record id="action_bao_cao_tai_san" model="ir.actions.act_window">
            <field name="name">Báo cáo tài chính tài sản</field>
            <field name="res_model">bao_cao_tai_san</field>
            <field name="view_mode">tree,form</field>
        </record>

    </data>
</odoo>
