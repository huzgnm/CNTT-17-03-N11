<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ================================================================
             FORM VIEW
        ================================================================ -->
        <record id="view_khau_hao_hang_thang_form" model="ir.ui.view">
            <field name="name">khau_hao_hang_thang_form</field>
            <field name="model">khau_hao_hang_thang</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_ghi_so"
                            string="Ghi sổ kế toán"
                            type="object"
                            class="btn-primary"
                            attrs="{'invisible': [('trang_thai', '!=', 'nhap')]}"/>
                        <button name="action_xem_but_toan"
                            string="Xem bút toán"
                            type="object"
                            attrs="{'invisible': [('trang_thai', '!=', 'da_ghi_so')]}"/>
                        <button name="action_huy"
                            string="Hủy"
                            type="object"
                            class="btn-danger"
                            confirm="Hủy sẽ xóa bút toán liên quan. Bạn chắc chắn?"
                            attrs="{'invisible': [('trang_thai', '=', 'huy')]}"/>
                        <field name="trang_thai" widget="statusbar"
                            statusbar_visible="nhap,da_ghi_so"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="ma_khau_hao" readonly="1"/></h1>
                        </div>
                        <group>
                            <group string="Thông tin khấu hao">
                                <field name="tai_san_id"/>
                                <field name="ten_tai_san" readonly="1"/>
                                <field name="ky_thang"/>
                                <field name="ky_nam"/>
                                <field name="ky_khau_hao" readonly="1"/>
                                <field name="ngay_ghi_nhan"/>
                            </group>
                            <group string="Giá trị">
                                <field name="gia_tri_truoc_kh" readonly="1"/>
                                <field name="so_tien_khau_hao"/>
                                <field name="gia_tri_sau_kh" readonly="1"/>
                                <field name="luy_ke_khau_hao" readonly="1"/>
                            </group>
                        </group>
                        <group string="Kế toán">
                            <field name="account_move_id" readonly="1"/>
                        </group>
                        <group string="Ghi chú">
                            <field name="ghi_chu" nolabel="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ================================================================
             TREE VIEW
        ================================================================ -->
        <record id="view_khau_hao_hang_thang_tree" model="ir.ui.view">
            <field name="name">khau_hao_hang_thang_tree</field>
            <field name="model">khau_hao_hang_thang</field>
            <field name="arch" type="xml">
                <tree decoration-success="trang_thai == 'da_ghi_so'"
                      decoration-muted="trang_thai == 'huy'"
                      decoration-warning="trang_thai == 'nhap'">
                    <field name="ma_khau_hao"/>
                    <field name="tai_san_id"/>
                    <field name="ten_tai_san"/>
                    <field name="ky_khau_hao"/>
                    <field name="ky_thang" optional="hide"/>
                    <field name="ky_nam" optional="hide"/>
                    <field name="ngay_ghi_nhan"/>
                    <field name="gia_tri_truoc_kh"/>
                    <field name="so_tien_khau_hao"/>
                    <field name="gia_tri_sau_kh"/>
                    <field name="luy_ke_khau_hao"/>
                    <field name="account_move_id" optional="show"/>
                    <field name="trang_thai"
                        decoration-success="trang_thai == 'da_ghi_so'"
                        decoration-muted="trang_thai == 'huy'"
                        decoration-warning="trang_thai == 'nhap'"
                        widget="badge"/>
                </tree>
            </field>
        </record>

        <!-- ================================================================
             SEARCH VIEW
        ================================================================ -->
        <record id="view_khau_hao_hang_thang_search" model="ir.ui.view">
            <field name="name">khau_hao_hang_thang_search</field>
            <field name="model">khau_hao_hang_thang</field>
            <field name="arch" type="xml">
                <search>
                    <field name="ma_khau_hao"/>
                    <field name="tai_san_id"/>
                    <field name="ten_tai_san"/>
                    <field name="ky_nam"/>
                    <filter string="Tháng này" name="thang_nay"
                        domain="[('ky_thang', '=', (context_today()).month),
                                 ('ky_nam',  '=', (context_today()).year)]"/>
                    <filter string="Nháp" name="nhap" domain="[('trang_thai','=','nhap')]"/>
                    <filter string="Đã ghi sổ" name="da_ghi_so" domain="[('trang_thai','=','da_ghi_so')]"/>
                    <filter string="Đã hủy" name="huy" domain="[('trang_thai','=','huy')]"/>
                    <group expand="0" string="Nhóm theo">
                        <filter string="Tài sản" name="group_tai_san" context="{'group_by': 'tai_san_id'}"/>
                        <filter string="Năm" name="group_nam" context="{'group_by': 'ky_nam'}"/>
                        <filter string="Tháng" name="group_thang" context="{'group_by': 'ky_thang'}"/>
                        <filter string="Trạng thái" name="group_tt" context="{'group_by': 'trang_thai'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ================================================================
             GRAPH VIEW
        ================================================================ -->
        <record id="view_khau_hao_hang_thang_graph" model="ir.ui.view">
            <field name="name">khau_hao_hang_thang_graph</field>
            <field name="model">khau_hao_hang_thang</field>
            <field name="arch" type="xml">
                <graph string="Khấu hao theo tài sản" type="bar">
                    <field name="tai_san_id" type="row"/>
                    <field name="so_tien_khau_hao" type="measure"/>
                    <field name="luy_ke_khau_hao" type="measure"/>
                </graph>
            </field>
        </record>

        <!-- ================================================================
             PIVOT VIEW
        ================================================================ -->
        <record id="view_khau_hao_hang_thang_pivot" model="ir.ui.view">
            <field name="name">khau_hao_hang_thang_pivot</field>
            <field name="model">khau_hao_hang_thang</field>
            <field name="arch" type="xml">
                <pivot string="Phân tích khấu hao">
                    <field name="tai_san_id" type="row"/>
                    <field name="ky_nam" type="col"/>
                    <field name="so_tien_khau_hao" type="measure"/>
                    <field name="luy_ke_khau_hao" type="measure"/>
                </pivot>
            </field>
        </record>

        <!-- ================================================================
             ACTION
        ================================================================ -->
        <record id="action_khau_hao_hang_thang" model="ir.actions.act_window">
            <field name="name">Khấu hao hàng tháng</field>
            <field name="res_model">khau_hao_hang_thang</field>
            <field name="view_mode">tree,form,graph,pivot</field>
            <field name="search_view_id" ref="view_khau_hao_hang_thang_search"/>
        </record>
    </data>
</odoo>
