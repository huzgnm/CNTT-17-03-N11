<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron job: Tính khấu hao tài sản hàng tháng, chạy vào ngày 1 mỗi tháng lúc 00:00 -->
        <record id="cron_tinh_khau_hao_hang_thang" model="ir.cron">
            <field name="name">Tính khấu hao tài sản hàng tháng</field>
            <field name="model_id" ref="model_tai_san"/>
            <field name="state">code</field>
            <field name="code">model.cron_tinh_khau_hao_hang_thang()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">months</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="nextcall" eval="(datetime.now().replace(day=1) + relativedelta(months=1)).strftime('%Y-%m-01 00:00:00')"/>
        </record>
    </data>
</odoo>
