<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron 1: Tính khấu hao hàng tháng -->
        <record id="cron_tinh_khau_hao" model="ir.cron">
            <field name="name">QLTS: Tính khấu hao hàng tháng</field>
            <field name="model_id" ref="model_tai_san"/>
            <field name="state">code</field>
            <field name="code">model.cron_tinh_khau_hao_hang_thang()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">months</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>

        <!-- Cron 2: Cảnh báo bảo trì quá hạn (chạy hàng tuần) -->
        <record id="cron_canh_bao_bao_tri" model="ir.cron">
            <field name="name">QLTS: Kiểm tra cảnh báo bảo trì quá hạn</field>
            <field name="model_id" ref="model_tai_san"/>
            <field name="state">code</field>
            <field name="code">model.cron_canh_bao_bao_tri()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">weeks</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>

        <!-- Cron 3: Cảnh báo bảo hành sắp hết hạn (chạy hàng ngày) -->
        <record id="cron_canh_bao_bao_hanh" model="ir.cron">
            <field name="name">QLTS: Kiểm tra bảo hành sắp hết hạn</field>
            <field name="model_id" ref="model_tai_san"/>
            <field name="state">code</field>
            <field name="code">model.cron_canh_bao_bao_hanh()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>
